# Copy this file to .env in the project root.
# Do not commit .env.

# Required for the main World Labs + OpenAI voice command flow.
OPENAI_API_KEY=
WORLDLABS_API_KEY=

# Optional image search.
PIXABAY_API_KEY=

# Optional audio search providers.
FREESOUND_API_KEY=
XENO_CANTO_API_KEY=

# Optional object-generation integrations.
MESHY_API_KEY=
TRIPO_API_KEY=
THREEDAISTUDIO_API_KEY=
THREEDAISTUDIO_BASE_URL=https://api.3daistudio.com
HITEM_ACCESS_KEY=
HITEM_SECRET_KEY=
HITEM_BASE_URL=https://api.hitem3d.ai

# Optional endpoint overrides for local/proxy testing.
FREESOUND_SEARCH_URL=
XENO_CANTO_SEARCH_URL=
OPENVERSE_AUDIO_SEARCH_URL=
