# Copy this file to .env in the project root.
# Do not commit .env.

# Required for the main World Labs + OpenAI voice command flow.
OPENAI_API_KEY=
WORLDLABS_API_KEY=

# Optional image search.
PIXABAY_API_KEY=

# Optional audio search providers.
FREESOUND_API_KEY=
XENO_CANTO_API_KEY=

# Reserved for future object-generation integrations.
MESHY_API_KEY=
TRIPO_API_KEY=
HITEM_API_KEY=

# Optional endpoint overrides for local/proxy testing.
FREESOUND_SEARCH_URL=
XENO_CANTO_SEARCH_URL=
OPENVERSE_AUDIO_SEARCH_URL=
